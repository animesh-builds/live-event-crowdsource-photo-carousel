# Server-side only — never exposed to client bundle
GOOGLE_DRIVE_API_KEY=
GOOGLE_DRIVE_FOLDER_ID=

# Client-side — embedded in JS at build time. Redeploy required after changes.
NEXT_PUBLIC_EVENT_TITLE=
NEXT_PUBLIC_EVENT_SUBTITLE=
NEXT_PUBLIC_THEME=midnight
NEXT_PUBLIC_SITE_PASSWORD=
NEXT_PUBLIC_UPLOAD_FORM_URL=
NEXT_PUBLIC_REFRESH_INTERVAL=300000

# See docs/setup_guide.md for integration topology and configuration strategy.
